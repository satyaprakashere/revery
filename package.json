{
  "name": "revery",
  "version": "0.32.0",
  "description": "App toolkit built with Reason",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bryphe/revery/issues"
  },
  "scripts": {
    "test": "esy b dune runtest",
    "format": "esy #{os == 'windows' ? 'b' : ''} bash .ci/format.sh #{os}",
    "run": "esy @examples x Examples"
  },
  "homepage": "https://github.com/bryphe/revery#readme",
  "esy": {
    "buildEnv": {
      "PATH": "/Users/prakash/github/revery/_build/bin:$PATH",
      "PKG_CONFIG_PATH": "/usr/lib64/pkgconfig:$PKG_CONFIG_PATH"
    },
    "exportedEnv": {
      "PKG_CONFIG_PATH": {
        "val": "/usr/lib64/pkgconfig:$PKG_CONFIG_PATH",
        "scope": "global"
      },
      "CFLAGS": {
        "val": "-Wno-error=implicit-function-declaration -Wno-error=incompatible-function-pointer-types",
        "scope": "global"
      }
    },
    "build": "dune build -p reason-harfbuzz,reason-skia,reason-sdl2,Revery",
    "install": [
      "esy-installer reason-harfbuzz.install",
      "esy-installer reason-skia.install",
      "esy-installer reason-sdl2.install",
      "esy-installer Revery.install",
      "bash -c \"#{os == 'windows' ? 'cp /usr/x86_64-w64-mingw32/sys-root/mingw/bin/*.dll \\'$cur__bin\\'': ':'}\"",
      "bash -c \"cp #{esy-skia.bin}/skia.dll \\'$cur__bin\\' #{os == 'windows' ? '' : '2>/dev/null || true'}\"",
      "bash -c \"cp #{esy-sdl2.bin}/*.dll \\'$cur__bin\\' #{os == 'windows' ? '' : '2>/dev/null || true'}\"",
      "bash -c \"cp #{esy-angle-prebuilt.bin}/*.dll \\'$cur__bin\\' #{os == 'windows' ? '' : '2>/dev/null || true'}\""
    ]
  },
  "dependencies": {
    "@opam/bos": "*",
    "@opam/ctypes": "*",
    "@opam/dune": "^3.8.0",
    "@opam/dune-configurator": "*",
    "@opam/reason": "^3.8.0",
    "@opam/lru": "*",
    "@opam/lwt": "^5.7.0",
    "@opam/lwt_ppx": "^5.9.3",
    "@opam/markup": "*",
    "@opam/ppx_deriving": "*",
    "@opam/ppx_optcomp": "*",
    "@opam/omd": "*",
    "@opam/uucp": "*",
    "@opam/uutf": "*",
    "@opam/charInfo_width": "*",
    "@brisk/brisk-reconciler": "file:./deps/brisk-reconciler",
    "esy-angle-prebuilt": "1.0.0",
    "esy-freetype2": "file:./deps/esy-freetype2",
    "@onivim/reason-native-crash-utils": "^1.0.2",
    "@revery/esy-harfbuzz": "file:./deps/esy-harfbuzz",
    "esy-skia": "file:./deps/esy-skia",
    "esy-sdl2": "file:./deps/esy-sdl2",
    "flex": "file:./deps/flex",
    "reperf": "file:./deps/reperf",
    "rench": "^1.10.0",
    "rebez": "file:./deps/rebez",
    "@revery/timber": "file:./deps/timber",
    "@reason-native/rely": "^3.2.1"
  },
  "resolutions": {
    "esy-sdl2": "path:./deps/esy-sdl2",
    "esy-freetype2": "path:./deps/esy-freetype2",
    "@revery/esy-harfbuzz": "path:./deps/esy-harfbuzz",
    "@opam/cmdliner": "1.3.0",
    "reperf": "path:./deps/reperf",
    "@brisk/brisk-reconciler": "path:./deps/brisk-reconciler",
    "@esy-ocaml/reason": "path:./deps/reason",
    "reason-cli": "path:./deps/reason-cli",
    "@opam/reason-cli": "path:./deps/opam-reason-cli",
    "reason": "path:./deps/reason",
    "@opam/reason": "path:./deps/reason",
    "@revery/timber": "path:./deps/timber",
    "flex": "path:./deps/flex",
    "flex/reason-cli": "path:./deps/reason-cli",
    "@revery/timber/reason-cli": "path:./deps/reason-cli",
    "@reason-native/rely/reason-cli": "path:./deps/reason-cli",
    "flex/reason": "path:./deps/reason",
    "@revery/timber/reason": "path:./deps/reason",
    "@reason-native/rely/reason": "path:./deps/reason",
    "@reason-native/cli": "path:./deps/reason-native",
    "@reason-native/pastel": "path:./deps/reason-native/pastel.json",
    "@reason-native/file-context-printer": "path:./deps/reason-native/file-context-printer.json",
    "@reason-native/rely": "path:./deps/reason-native/rely.json"
  },
  "devDependencies": {
    "ocaml": "~5.2.0",
    "esy-astyle": "./deps/esy-astyle",
    "@opam/ocaml-lsp-server": "1.21.0"
  }
}
